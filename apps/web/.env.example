# ============================================
# ClubOS — Environment Variables
# ============================================
# Copy to .env.local and fill in values.
# For staging, copy to .env.staging.local instead.
#
# Environment hierarchy:
#   Local dev  → .env.local
#   Staging    → .env.staging.local (+ Vercel env vars)
#   Production → Vercel env vars only (never commit!)

# ── Supabase ────────────────────────────────
# Local:   http://127.0.0.1:54321 (supabase start)
# Staging: https://<staging-project>.supabase.co
# Prod:    https://iicwnlruopqhrzkgjsmu.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ──────────────────────────────────
# Use test keys for local + staging, live keys for prod only.
# Same Stripe account — just toggle test/live mode.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI Chat (Claude) ───────────────────────
ANTHROPIC_API_KEY=

# ── Email (Resend) ─────────────────────────
# Staging: use dev domain (e.g. dev@resend.dev or your verified test domain)
# Prod: use production domain (e.g. notifications@greenfieldcc.com)
RESEND_API_KEY=

# ── App Config ──────────────────────────────
# Set per environment. Used by mobile app to call web API.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://clubos-staging.vercel.app   # staging
# NEXT_PUBLIC_APP_URL=https://clubos.vercel.app           # prod

# ── Environment Indicator ───────────────────
# "development" | "staging" | "production"
NEXT_PUBLIC_ENV=development
